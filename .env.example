ANTHROPIC_API_KEY=""

# Python Orbital Engine
ORBITAL_ENGINE_URL="http://localhost:8000"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (optional, for caching)
REDIS_URL=""

# Cron Secret (for scheduled TLE refresh)
CRON_SECRET=""
