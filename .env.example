# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/orbitra?schema=public"

# CelesTrak API
CELESTRAK_BASE_URL="https://celestrak.org/NORAD/elements/gp.php"

# AI Narration (OpenAI / Anthropic)
